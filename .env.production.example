# 生产后端环境变量模板 —— 复制为 .env.production 并填真实值 (.env.production 不要进 git)
# 与 docker-compose.yml 的 backend 服务配套使用。

# --- 数据库 ---
# MYSQL_ROOT_PASSWORD 供 docker compose 给 mysql 容器设密码 (compose --env-file 读它);
# DATABASE_URL 里 root 后面的密码必须与之【完全一致】(host 用服务名 mysql, 端口 3306)。
# 改密码时两处一起改。注意: 不要带特殊字符破坏 URL, 或对 @ : / 做 URL 编码。
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL="mysql+aiomysql://root:CHANGE_ME_STRONG_DB_PASSWORD@mysql:3306/saas_agent_db"

# --- 大模型 (换用生产专用 key, 勿复用泄露过的) ---
LLM_API_KEY="CHANGE_ME"
LLM_BASE_URL="https://api.easycostai.com/v1"
LLM_MODEL_NAME="gemini-2.5-pro"
LLM_EMBEDDING_MODEL="text-embedding-3-small"

# --- 向量库 / 记忆 ---
# 生产使用独立 Qdrant 服务。RAG 知识库和 Mem0 记忆共用此服务，通过 collection 隔离。
QDRANT_URL="http://qdrant:6333"
QDRANT_API_KEY=""
QDRANT_ON_DISK=False

# 本地未配置 QDRANT_URL/HOST 时才会回退到嵌入式 path 模式。
MEMORY_DB_PATH="./memory_db"
QDRANT_DATA_PATH="./qdrant_data"

# --- 上传目录 (对应 compose 卷挂载点) ---
UPLOAD_DIR="./uploads"

# --- 系统 ---
DEBUG_MODE=False
WEB_CONCURRENCY=2

# --- JWT (生产换成新随机长串, 例: openssl rand -hex 32) ---
JWT_SECRET="CHANGE_ME_RANDOM_LONG_SECRET"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=1440

# --- 同源, 单域名 ---
FRONTEND_ORIGINS="https://uchat.sohoclouds.com"
PUBLIC_BASE_URL="https://uchat.sohoclouds.com"
